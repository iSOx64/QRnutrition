## Local environment variables (DO NOT COMMIT .env)
#
# Create your own `.env` next to this file:
#   cp .env.example .env
#
# Notes:
# - This app currently has safe defaults for OpenFoodFacts URLs.
# - Keep Firebase secrets out of this file; use FlutterFire CLI instead.

# OpenFoodFacts endpoints (optional overrides)
OPENFOODFACTS_BASE_PRODUCT_URL=https://world.openfoodfacts.net/api/v2/product
OPENFOODFACTS_BASE_SEARCH_URL=https://world.openfoodfacts.net/api/v2/search

# Optional: set to true if you want extra logs (if you wire it in later)
APP_DEBUG=false

